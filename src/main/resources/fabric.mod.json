{
	"schemaVersion": 1,
	"id": "voice_mouth",
	"version": "${version}",
	"name": "VoiceMouth",
	"description": "This is a plugin for Simple Voice Chat that displays the mouth when the player speaks!",
	"authors": [
		"ginterloper"
	],
	"contact": {
		"sources": "https://github.com/ginterloper/VoiceMouth/"
	},
	"license": "CC BY-NC 4.0",
	"icon": "assets/voicemouth/icon.png",
	"environment": "*",
	"entrypoints": {
        "main": [
          "me.ginterloper.VoiceMouth"
        ],
        "client": [
          "me.ginterloper.client.VoiceMouthClient"
        ],
        "voicechat": [
          "me.ginterloper.client.SimpleVoiceChatPlugin"
        ]
	},
	"mixins": [
		"mouth-voice.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.2",
		"java": ">=21"
	}
}